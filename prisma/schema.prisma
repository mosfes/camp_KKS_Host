// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum role {
  TEACHER
  CAMP_LEADER
  ADMIN
}

model teachers {
  teachers_id Int       @id @default(autoincrement())
  prefix_name String?   @db.VarChar(255)
  role        role      @default(TEACHER)
  firstname   String    @db.VarChar(255)
  lastname    String    @db.VarChar(255)
  tel         String    @db.VarChar(10)
  email       String    @db.VarChar(255)
  deletedAt   DateTime?

  classrooms         classrooms[]
  classroom_teacher  classroom_teacher[]
  camp               camp[]
  teacher_enrollment teacher_enrollment[]
  survey_template    survey_template[]

  @@index([deletedAt])
}

model students {
  students_id     Int       @id
  prefix_name     String?   @db.VarChar(255)
  firstname       String    @db.VarChar(255)
  lastname        String    @db.VarChar(255)
  birthday        DateTime?
  food_allergy    String?   @db.VarChar(255)
  chronic_disease String?   @db.VarChar(255)
  remark          String?   @db.VarChar(255)
  tel             String?   @db.VarChar(10)
  email           String    @db.VarChar(255)
  deletedAt       DateTime?

  parents                    parents[]
  classroom_students         classroom_students[]
  student_enrollment         student_enrollment[]
  attendance_record_student  attendance_record_student[]

  @@index([deletedAt])
}

model parents {
  parents_id Int    @id @default(autoincrement())
  firstname  String @db.VarChar(255)
  lastname   String @db.VarChar(255)
  tel        String @db.VarChar(10)
  password   String @db.VarChar(255)

  username_student_id Int
  student             students @relation(fields: [username_student_id], references: [students_id])
}

model academic_years {
  // years_id   Int          @id @default(autoincrement())
  status     String       @db.VarChar(255) // ลบ จัดเก็บ แอคทีฟ
  year       Int          @id
  classrooms classrooms[]
}

model classrooms {
  classroom_id            Int            @id @default(autoincrement())
  deletedAt               DateTime?
  // type_classroom          String         @db.VarChar(255)
  grade                   GradeLevel
  academic_years_years_id Int
  academic_years          academic_years @relation(fields: [academic_years_years_id], references: [year])

  teachers_teachers_id Int
  teacher              teachers @relation(fields: [teachers_teachers_id], references: [teachers_id])

  type_classroom  Int
  classroom_types classroom_types @relation(fields: [type_classroom], references: [classroom_type_id])

  classroom_teacher  classroom_teacher[]
  classroom_students classroom_students[]
  camp_classroom     camp_classroom[]

  @@index([deletedAt])
}

model classroom_types {
  classroom_type_id Int    @id @default(autoincrement())
  name              String @unique @db.VarChar(255)
  valid_grades      String @db.VarChar(255)

  classrooms classrooms[]
}

enum GradeLevel {
  Level_1 @map("1")
  Level_2 @map("2")
  Level_3 @map("3")
  Level_4 @map("4")
  Level_5 @map("5")
  Level_6 @map("6")
}

model classroom_teacher {
  classroom_teacher_id   Int @id @default(autoincrement())
  classroom_classroom_id Int
  teacher_teachers_id    Int

  classroom classrooms @relation(fields: [classroom_classroom_id], references: [classroom_id])
  teacher   teachers   @relation(fields: [teacher_teachers_id], references: [teachers_id])
}

model classroom_students {
  classroom_students_id  Int @id @default(autoincrement())
  classroom_classroom_id Int
  student_students_id    Int

  classroom classrooms @relation(fields: [classroom_classroom_id], references: [classroom_id])
  student   students   @relation(fields: [student_students_id], references: [students_id])
}

model camp {
  camp_id          Int         @id @default(autoincrement())
  deletedAt        DateTime?
  location         String      @db.VarChar(255)
  name             String      @db.VarChar(255)
  start_date       DateTime
  end_date         DateTime
  start_shirt_date DateTime
  end_shirt_date   DateTime
  start_regis_date DateTime
  end_regis_date   DateTime
  description      String      @db.Text
  status           camp_status @default(OPEN)
  has_shirt        Boolean     @default(false)
  img_camp_url     String      @db.VarChar(500)
  img_shirt_url    String      @db.VarChar(500)

  // plan_type_plane_id Int
  // plan_type          plan_type @relation(fields: [plan_type_plane_id], references: [plane_id])

  created_by_teacher_id Int
  created_by            teachers @relation(fields: [created_by_teacher_id], references: [teachers_id])

  camp_template       camp_template[]
  camp_classroom      camp_classroom[]
  teacher_enrollment  teacher_enrollment[]
  student_enrollment  student_enrollment[]
  attendance_session  attendance_session[]
  attendance_teachers attendance_teachers[]
  station             station[]
  camp_daily_schedule camp_daily_schedule[]
  survey              survey[]

  @@index([deletedAt])
  @@index([created_by_teacher_id])
}

enum camp_status {
  OPEN
  CLOSED
}

// model plan_type {
//   plane_id Int        @id @default(autoincrement())
//   name     plan_type_
//   // camp     camp[]
// }

// enum plan_type_ {
//   new
//   continue
// }

model camp_daily_schedule {
  daily_schedule_id Int @id @default(autoincrement())

  camp_camp_id Int
  camp         camp @relation(fields: [camp_camp_id], references: [camp_id])

  day Int

  time_slots camp_time_slot[]
}

model camp_time_slot {
  time_slot_id Int @id @default(autoincrement())

  daily_schedule_id Int
  daily_schedule    camp_daily_schedule @relation(fields: [daily_schedule_id], references: [daily_schedule_id])

  startTime String @db.VarChar(5)
  endTime   String @db.VarChar(5)
  activity  String @db.VarChar(255)
}

model camp_template {
  camp_template_id Int    @id @default(autoincrement())
  name             String @db.VarChar(255)

  camp_camp_id Int
  camp         camp @relation(fields: [camp_camp_id], references: [camp_id])
}

model camp_classroom {
  camp_classroom_id      Int @id @default(autoincrement())
  camp_camp_id           Int
  classroom_classroom_id Int

  camp      camp       @relation(fields: [camp_camp_id], references: [camp_id])
  classroom classrooms @relation(fields: [classroom_classroom_id], references: [classroom_id])
}

model teacher_enrollment {
  teacher_enrollment_id Int @id @default(autoincrement())

  teacher_teachers_id Int
  teacher             teachers              @relation(fields: [teacher_teachers_id], references: [teachers_id])
  camp_camp_id        Int
  camp                camp                  @relation(fields: [camp_camp_id], references: [camp_id])
  attendance_teachers attendance_teachers[]
}

model student_enrollment {
  student_enrollment_id Int       @id @default(autoincrement())
  enrolled_at           DateTime? // null = ยังไม่ได้กดเข้าร่วม
  shirt_size            String?   @db.VarChar(10) // null = ยังไม่ได้ระบุ
  // jorn DateTime @default(now()) // นักเรียนลงทะเบียน

  student_students_id Int
  student             students          @relation(fields: [student_students_id], references: [students_id])
  camp_camp_id        Int
  camp                camp              @relation(fields: [camp_camp_id], references: [camp_id])
  certificate         certificate[]
  mission_result      mission_result[]
  survey_response     survey_response[]

  @@unique([student_students_id, camp_camp_id])
  @@index([camp_camp_id])
}

model attendance_session {
  id           Int      @id @default(autoincrement())
  camp_camp_id Int
  camp         camp     @relation(fields: [camp_camp_id], references: [camp_id])
  round_id     String   @db.VarChar(64) // string id เช่น "l9x3r2ab"
  round_number Int
  description  String   @db.VarChar(255)
  nonce        String   @db.VarChar(64)
  pin          String   @db.VarChar(10)
  generated_at DateTime @default(now())
  expires_at   DateTime
  is_closed    Boolean  @default(false)
  closed_at    DateTime?

  @@index([camp_camp_id])
  @@index([round_id])
}

model attendance_record_student {
  record_id                     Int      @id @default(autoincrement())
  checkin_time                  DateTime
  attendance_teacher_session_id Int
  student_students_id           Int
  image_url                     String?  @db.Text

  attendance_teachers_session_id attendance_teachers @relation(fields: [attendance_teacher_session_id], references: [session_id])
  student                        students            @relation(fields: [student_students_id], references: [students_id])
}

model attendance_teachers {
  session_id                               Int                        @id @default(autoincrement())
  description                              String                     @db.Text
  method                                   attendance_teachers_method
  created_at                               DateTime                   @default(now())
  expires_at                               DateTime?
  round_id                                 String?                    @db.VarChar(64)
  round_number                             Int                        @default(1)
  is_closed                                Boolean                    @default(false)
  closed_at                                DateTime?
  camp_camp_id                             Int
  camp                                     camp                       @relation(fields: [camp_camp_id], references: [camp_id])
  teacher_enrollment_teacher_enrollment_id Int
  teacher_enrollment                       teacher_enrollment         @relation(fields: [teacher_enrollment_teacher_enrollment_id], references: [teacher_enrollment_id])

  attendance_record_student attendance_record_student[]
}

enum attendance_teachers_method {
  QR
  NFC
  Image
  default
}

model certificate {
  certificate_id        Int                @id @default(autoincrement())
  issue_date            DateTime           @default(now())
  file_url              String             @db.VarChar(500)
  certificate_no        Int
  certificate_no_star   Int
  student_enrollment_id Int
  student_enrollment    student_enrollment @relation(fields: [student_enrollment_id], references: [student_enrollment_id])
}

model station {
  station_id  Int    @id @default(autoincrement())
  name        String @db.VarChar(255)
  description String @db.VarChar(255)

  camp_camp_id Int
  camp         camp @relation(fields: [camp_camp_id], references: [camp_id])

  mission   mission[]
  deletedAt DateTime?

  @@index([deletedAt])
}

enum MissionType {
  QUESTION_ANSWERING
  PHOTO_SUBMISSION
  QR_CODE_SCANNING
  MULTIPLE_CHOICE_QUIZ
  PRE_TEST
  POST_TEST
}

model mission {
  mission_id  Int         @id @default(autoincrement())
  title       String?     @db.VarChar(255)
  description String?     @db.Text
  type        MissionType @default(QUESTION_ANSWERING)
  // instructions String? @db.Text

  station_station_id Int
  station            station @relation(fields: [station_station_id], references: [station_id])

  mission_result   mission_result[]
  mission_question mission_question[]
  deletedAt        DateTime?

  @@index([deletedAt])
}

model mission_result {
  mission_result_id Int                   @id @default(autoincrement())
  method            mission_result_method
  status            mission_result_status
  submitted_at      DateTime              @default(now())

  student_enrollment_id Int
  student_enrollment    student_enrollment @relation(fields: [student_enrollment_id], references: [student_enrollment_id])
  mission_mission_id    Int
  mission               mission            @relation(fields: [mission_mission_id], references: [mission_id])

  mission_answer mission_answer[]

  @@index([student_enrollment_id, mission_mission_id])
}

enum mission_result_method {
  NFC
  QR
  Code
  Aws
  Photo
}

enum mission_result_status {
  pending
  completed
}

model mission_question {
  question_id   Int                   @id @default(autoincrement())
  question_text String                @db.VarChar(255)
  question_type mission_question_type

  mission_mission_id Int
  mission            mission                   @relation(fields: [mission_mission_id], references: [mission_id])
  mission_answer     mission_answer[]
  choices            mission_question_choice[]
}

enum mission_question_type {
  MCQ
  TEXT
  PHOTO
}

model mission_question_choice {
  choice_id   Int     @id @default(autoincrement())
  choice_text String  @db.VarChar(255)
  is_correct  Boolean @default(false)

  mission_question_question_id Int
  mission_question             mission_question @relation(fields: [mission_question_question_id], references: [question_id], onDelete: Cascade)
}

model mission_answer {
  answer_id                        Int @id @default(autoincrement())
  mission_result_mission_result_id Int

  mission_result               mission_result   @relation(fields: [mission_result_mission_result_id], references: [mission_result_id])
  mission_question_question_id Int
  mission_question             mission_question @relation(fields: [mission_question_question_id], references: [question_id])

  answer_mcq   mission_answer_mcq[]
  answer_text  mission_answer_text[]
  answer_photo mission_answer_photo[]
}

model mission_answer_photo {
  id Int @id @default(autoincrement())

  mission_answer_id Int
  mission_answer    mission_answer @relation(fields: [mission_answer_id], references: [answer_id])

  img_url String @db.Text
}

model mission_answer_mcq {
  id                Int            @id @default(autoincrement())
  mission_answer_id Int
  mission_answer    mission_answer @relation(fields: [mission_answer_id], references: [answer_id])
  question_text     String         @db.VarChar(1)
}

model mission_answer_text {
  id                Int            @id @default(autoincrement())
  mission_answer_id Int
  mission_answer    mission_answer @relation(fields: [mission_answer_id], references: [answer_id])
  answer_text       String         @db.Text
}

model suggestion_analysis_summary {
  suggestion_analysis_summary_id Int             @id @default(autoincrement())
  summary_text                   String          @db.Text
  overall_sentiment              String          @db.VarChar(255)
  positive_themes                String          @db.Text
  improvement_areas              String          @db.Text
  positive_percentage            Float
  negative_percentage            Float
  survey_response_id             Int
  survey_response                survey_response @relation(fields: [survey_response_id], references: [response_id])
  survey_answer_id               Int
  survey_answer                  survey_answer   @relation(fields: [survey_answer_id], references: [answer_id])
}

model vulgar_words {
  vulgar_word_id Int      @id @default(autoincrement())
  word           String   @db.VarChar(255)
  is_ai          Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model survey {
  survey_id   Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  created_at  DateTime @default(now())

  camp_camp_id Int  @unique
  camp         camp @relation(fields: [camp_camp_id], references: [camp_id])

  survey_question survey_question[]
  survey_response survey_response[]
}

model survey_question {
  question_id   Int                  @id @default(autoincrement())
  question_text String               @db.VarChar(255)
  question_type survey_question_type
  scale_max     Int?

  survey_survey_id Int
  survey           survey @relation(fields: [survey_survey_id], references: [survey_id], onDelete: Cascade)

  survey_answer survey_answer[]
}

// ติดตามว่านักเรียนคนไหนทำแบบสอบถามเสร็จแล้ว (สำหรับปลดล็อคประกาศนียบัตร)
model survey_response {
  response_id  Int      @id @default(autoincrement())
  submitted_at DateTime @default(now())

  survey_survey_id Int
  survey           survey @relation(fields: [survey_survey_id], references: [survey_id])

  student_enrollment_id       Int
  student_enrollment          student_enrollment            @relation(fields: [student_enrollment_id], references: [student_enrollment_id])
  suggestion_analysis_summary suggestion_analysis_summary[]
  survey_answer               survey_answer[]

  @@unique([survey_survey_id, student_enrollment_id])
}

model survey_answer {
  answer_id   Int     @id @default(autoincrement())
  text_answer String? @db.Text
  scale_value Int?

  survey_response_id Int
  survey_response    survey_response @relation(fields: [survey_response_id], references: [response_id], onDelete: Cascade)

  question_id                 Int
  survey_question             survey_question               @relation(fields: [question_id], references: [question_id])
  suggestion_analysis_summary suggestion_analysis_summary[]
}

// เทมเพลตแบบสอบถาม เพื่อนำกลับมาใช้ในครั้งต่อไป
model survey_template {
  template_id Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  created_at  DateTime @default(now())

  created_by_teacher_id Int
  created_by            teachers @relation(fields: [created_by_teacher_id], references: [teachers_id])

  survey_template_question survey_template_question[]
}

model survey_template_question {
  question_id   Int                  @id @default(autoincrement())
  question_text String               @db.VarChar(255)
  question_type survey_question_type
  scale_max     Int?

  template_id Int
  template    survey_template @relation(fields: [template_id], references: [template_id], onDelete: Cascade)
}

enum survey_question_type {
  text
  scale
  header
}
